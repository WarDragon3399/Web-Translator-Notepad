{
  "manifest_version": 3,
  "name": "Web Translator Notepad",
  "version": "3.0.0",
  "description": "A lightweight, dark-mode translator notepad with voice input and sharing features.",
  "short_name": "TransPad",
 "icons": {
    "128": "icon.png"
  },
  "permissions": ["tabs", "storage", "scripting", "clipboardRead"],
  "incognito": "split",
  "action": {
    "default_icon": "icon.png",
    "default_title": "Web Translator Notepad"
  },
  "background": {
    "service_worker": "background.js"
  }
}
