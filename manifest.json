{
  "manifest_version": 3,
  "name": "Web Translator Notepad",
  "version": "1.0.0",
  "description": "A lightweight, dark-mode translator notepad with voice input and sharing features.",
  "short_name": "TransPad",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["tabs", "storage"],
  "action": {
    "default_icon": "icon.png",
    "default_title": "Open Translator Notepad"
  },
  "background": {
    "service_worker": "background.js"
  }
}